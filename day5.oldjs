function countVowels(str) {
    let count = 0;
    str = str.toLowerCase();

    for (let i = 0; i < str.length; i++) {
        if ("aeiou".includes(str[i])) {
            count++;
        }   
    }
    return count;
}

console.log(countVowels("hello")); // 2
console.log(countVowels("AEIOU")); // 5
console.log(countVowels("rythm")); // 0